<!DOCTYPE html>
<html lang="cs" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Sensei - Přehled pro Vedení Škol</title>
    <!-- Načtení Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Načtení ikon Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* Definice barev podle via.academy */
        :root {
            --bg-sidebar: #276749; /* Tmavě zelená */
            --bg-sidebar-active: #2F855A;
            --text-sidebar-inactive: #C6F6D5;
            --text-sidebar-active: #FFFFFF;
            --bg-content: #F4F7F6; /* Velmi světle šedozelené pozadí */
            --bg-card: #FFFFFF;
            --text-hlavni: #2D3748;
            --accent-green: #38A169;
            --accent-orange: #DD6B20;
        }

        /* Vlastní písma */
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-content);
            color: var(--text-hlavni);
        }

        /* --- Styly pro animace při posouvání --- */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease-out, transform 0.6s ease-out;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* Odhalení v sekvenci */
        .reveal-child {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.6s ease-out, transform 0.6s ease-out;
        }
        .reveal.visible .reveal-child {
            opacity: 1;
            transform: translateY(0);
        }
        .reveal.visible .delay-1 { transition-delay: 200ms; }
        .reveal.visible .delay-2 { transition-delay: 400ms; }
        .reveal.visible .delay-3 { transition-delay: 600ms; }
        .reveal.visible .delay-4 { transition-delay: 800ms; }
        .reveal.visible .delay-5 { transition-delay: 1000ms; }
        .reveal.visible .delay-6 { transition-delay: 1200ms; }

        /* --- Animace pro Problém (Sekce 1) --- */
        #problem-flow > div, #problem-flow > i {
            opacity: 0;
            transform: scale(0.9);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .reveal.visible #problem-flow > div:nth-child(1) { opacity: 1; transform: scale(1); transition-delay: 300ms; }
        .reveal.visible #problem-flow > i:nth-child(2) { opacity: 1; transform: scale(1); transition-delay: 600ms; }
        .reveal.visible #problem-flow > div:nth-child(3) { opacity: 1; transform: scale(1); transition-delay: 900ms; animation: pulse-blackbox 2s infinite 1s; }
        .reveal.visible #problem-flow > i:nth-child(4) { opacity: 1; transform: scale(1); transition-delay: 1200ms; }
        .reveal.visible #problem-flow > div:nth-child(5) { opacity: 1; transform: scale(1); transition-delay: 1500ms; }

        @keyframes pulse-blackbox {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); border-color: var(--accent-orange); }
            100% { transform: scale(1); }
        }

        /* --- Animace pro Ekosystém (Sekce 2) --- */
        #ecosystem-loop > div, #ecosystem-loop > i {
            opacity: 0;
            transform: scale(0.9);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .reveal.visible #ecosystem-loop > div:nth-child(1) { opacity: 1; transform: scale(1); transition-delay: 300ms; }
        .reveal.visible #ecosystem-loop > div:nth-child(2) { opacity: 1; transform: scale(1); transition-delay: 500ms; }
        .reveal.visible #ecosystem-loop > div:nth-child(3) { opacity: 1; transform: scale(1); transition-delay: 700ms; }
        .reveal.visible #ecosystem-loop > i { opacity: 0.5; transform: scale(1); transition-delay: 1000ms; }

    </style>
</head>
<body class="bg-gray-50">

    <!-- Navigace (Minimalistická) -->
    <nav class="sticky top-0 z-50 bg-white shadow-sm">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center">
                <i class="fa-solid fa-brain text-3xl mr-3" style="color: var(--bg-sidebar);"></i>
                <span class="text-2xl font-bold" style="color: var(--text-hlavni); font-family: 'Poppins', sans-serif;">AI Sensei</span>
            </div>
            <a href="#demo" class="px-5 py-2 bg-accent-orange text-white font-semibold rounded-lg shadow-md hover:bg-orange-700 transition duration-300">
                Dohodnout demo
            </a>
        </div>
    </nav>

    <!-- Sekce 0: Hero (Úvod) -->
    <header class="bg-white">
        <div class="max-w-6xl mx-auto px-6 py-20 md:py-32 text-center">
            <h1 class="text-4xl md:text-6xl font-bold mb-6" style="color: var(--text-hlavni); font-family: 'Poppins', sans-serif;">
                Jak oslovit Generaci Z
            </h1>
            <p class="text-xl md:text-2xl text-gray-600 mb-10">
                A získat přitom data o výuce v reálném čase?
            </p>
            <a href="#problem" class="px-8 py-4 bg-accent-green text-white text-lg font-semibold rounded-lg shadow-lg hover:bg-green-700 transition duration-300">
                Zjistit, jak (1 minuta)
            </a>
        </div>
    </header>

    <!-- Sekce 1: Problém (Černá skříňka) -->
    <section id="problem" class="py-20 md:py-28 bg-gray-50">
        <div class="max-w-6xl mx-auto px-6 reveal">
            <h2 class="text-3xl md:text-4xl font-bold text-center mb-6" style="color: var(--text-hlavni);">Proč tradiční metody selhávají?</h2>
            <p class="text-lg text-gray-600 text-center mb-16 max-w-3xl mx-auto">
                Vedení školy často postrádá přehled. Nevíte, kdo zaostává, dokud není pozdě na nápravu.
            </p>
            
            <!-- Grafika: Černá skříňka -->
            <div id="problem-flow" class="flex flex-col md:flex-row items-center justify-center space-y-4 md:space-y-0 md:space-x-6">
                
                <!-- Krok 1: Profesor -->
                <div class="flex flex-col items-center p-6 bg-white rounded-xl shadow-lg border border-gray-200">
                    <i class="fa-solid fa-user-tie text-6xl" style="color: var(--accent-green);"></i>
                    <span class="mt-4 font-semibold text-lg" style="color: var(--text-hlavni);">Profesor učí</span>
                </div>

                <i class="fa-solid fa-arrow-right-long text-4xl text-gray-300 transform md:rotate-0 rotate-90"></i>

                <!-- Krok 2: Černá skříňka -->
                <div class="flex flex-col items-center p-6 bg-white rounded-xl shadow-lg border-2 border-dashed border-gray-400">
                    <i class="fa-solid fa-question text-6xl" style="color: var(--accent-orange);"></i>
                    <span class="mt-4 font-semibold text-lg" style="color: var(--text-hlavni);">Černá skříňka</span>
                </div>
                
                <i class="fa-solid fa-arrow-right-long text-4xl text-gray-300 transform md:rotate-0 rotate-90"></i>

                <!-- Krok 3: Výsledky (Pozdě) -->
                <div class="flex flex-col items-center p-6 bg-white rounded-xl shadow-lg border border-gray-200">
                    <i class="fa-solid fa-file-excel text-6xl" style="color: var(--text-hlavni);"></i>
                    <span class="mt-4 font-semibold text-lg" style="color: var(--text-hlavni);">Výsledky (po 3 měs.)</span>
                </div>
            </div>
            
            <h3 class="text-2xl md:text-3xl font-bold text-center mt-16 reveal reveal-child delay-4" style="color: var(--accent-green);">
                Co kdybyste mohli vidět do celého procesu v reálném čase?
            </h3>
        </div>
    </section>

    <!-- Sekce 2: Transformácia (Ekosystém) -->
    <section id="transformace" class="py-20 md:py-28" style="background-color: var(--bg-sidebar);">
        <div class="max-w-6xl mx-auto px-6 text-center reveal">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Představujeme AI Sensei</h2>
            <p class="text-2xl font-semibold text-gray-200 mb-12">Inteligentní ekosystém, ne jen nástroj.</p>
            <p class="text-xl text-gray-300 mb-16 max-w-3xl mx-auto">
                AI Sensei propojuje vedení, profesory a studenty do jednoho funkčního celku.
            </p>
            
            <!-- Klíčová Animace: Ekosystém -->
            <div id="ecosystem-loop" class="relative flex flex-col items-center justify-center min-h-[300px]">
                
                <!-- Tři pilíře -->
                <div class="p-6 bg-white rounded-xl shadow-lg w-64 text-center absolute" style="top: 0; left: 50%; transform: translateX(-50%);">
                    <i class="fa-solid fa-landmark text-5xl" style="color: var(--accent-green);"></i>
                    <span class="mt-3 block font-semibold text-lg" style="color: var(--text-hlavni);">VEDENÍ ŠKOLY<br>(Data a přehled)</span>
                </div>

                <div class="p-6 bg-white rounded-xl shadow-lg w-64 text-center absolute" style="bottom: 0; left: 20%; transform: translateX(-50%);">
                    <i class="fa-solid fa-user-tie text-5xl" style="color: var(--accent-green);"></i>
                    <span class="mt-3 block font-semibold text-lg" style="color: var(--text-hlavni);">PROFESOR<br>(Nástroje a úspora)</span>
                </div>

                <div class="p-6 bg-white rounded-xl shadow-lg w-64 text-center absolute" style="bottom: 0; right: 20%; transform: translateX(50%);">
                    <i class="fa-solid fa-user-graduate text-5xl" style="color: var(--accent-green);"></i>
                    <span class="mt-3 block font-semibold text-lg" style="color: var(--text-hlavni);">STUDENT<br>(Obsah 24/7)</span>
                </div>

                <!-- Spojovací šipky (skryté na malých obrazovkách) -->
                <i class="fa-solid fa-arrows-left-right text-5xl text-white opacity-50 absolute hidden md:block" style="top: 150px; left: 36%;"></i>
                <i class="fa-solid fa-arrows-left-right text-5xl text-white opacity-50 absolute hidden md:block" style="top: 150px; right: 36%;"></i>
                <i class="fa-solid fa-arrows-left-right text-5xl text-white opacity-50 absolute hidden md:block" style="bottom: 30px; left: 50%; transform: translateX(-50%);"></i>

            </div>
        </div>
    </section>

    <!-- Sekce 3: Hodnota (Pro Vedení) -->
    <section id="hodnota" class="py-20 md:py-28 bg-white">
        <div class="max-w-6xl mx-auto px-6 reveal">
            <h2 class="text-3xl md:text-4xl font-bold text-center mb-16" style="color: var(--text-hlavni);">Klíčové přínosy pro Vedení</h2>
            
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Karta 1: Data -->
                <div class="reveal-child delay-1 p-8 bg-gray-50 rounded-xl shadow-md border border-gray-200">
                    <i class="fa-solid fa-chart-pie text-4xl mb-4" style="color: var(--accent-green);"></i>
                    <h3 class="text-2xl font-bold mb-3" style="color: var(--text-hlavni);">Data v reálném čase</h3>
                    <p class="text-gray-600">
                        Získejte okamžitý přehled o aktivitě studentů, úspěšnosti v testech a identifikujte, kdo zaostává, dříve než bude pozdě.
                    </p>
                </div>
                <!-- Karta 2: Gen Z -->
                <div class="reveal-child delay-2 p-8 bg-gray-50 rounded-xl shadow-md border border-gray-200">
                    <i class="fa-solid fa-mobile-screen-button text-4xl mb-4" style="color: var(--accent-green);"></i>
                    <h3 class="text-2xl font-bold mb-3" style="color: var(--text-hlavni);">Oslovení Generace Z</h3>
                    <p class="text-gray-600">
                        Poskytněte studentům učení 24/7 ve formátu, který znají: podcasty, kvízy a AI asistent. Vše dostupné v mobilu.
                    </p>
                </div>
                <!-- Karta 3: Bezpečnost -->
                <div class="reveal-child delay-3 p-8 bg-gray-50 rounded-xl shadow-md border border-gray-200">
                    <i class="fa-solid fa-shield-halved text-4xl mb-4" style="color: var(--accent-green);"></i>
                    <h3 class="text-2xl font-bold mb-3" style="color: var(--text-hlavni);">Bezpečnost a Kontrola</h3>
                    <p class="text-gray-600">
                        AI asistent čerpá informace *výhradně* z vašich ověřených materiálů. Žádné výmysly, žádný cizí obsah. Plná kontrola nad výukou.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Sekce 4: Výzva k Akcii (CTA) -->
    <section id="demo" class="py-20 md:py-28" style="background-color: var(--bg-content);">
        <div class="max-w-4xl mx-auto px-6 text-center reveal">
            <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--text-hlavni);">Zaujali jsme vás?</h2>
            <p class="text-xl text-gray-600 mb-10">
                Neukazujeme vám jen demo. Ukážeme vám, jak to doopravdy funguje.
            </p>
            
            <div class="flex flex-col md:flex-row gap-6 justify-center">
                <!-- Tlačítko 1: Odkaz na /prohlidka (kde bude ai_sensei_tour.html) -->
                <a href="/prohlidka" target="_blank" class="reveal-child delay-1 px-10 py-4 bg-green-700 text-white text-lg font-semibold rounded-lg shadow-lg hover:bg-green-800 transition duration-300 transform hover:scale-105">
                    <i class="fa-solid fa-rocket mr-2"></i> Spustit interaktivní prohlídku (2 min)
                </a>
                
                <!-- Tlačítko 2: Osobní demo -->
                <a href="mailto:demo@via.academy?subject=Zájem%20o%20osobní%20demo%20AI%20Sensei" class="reveal-child delay-2 px-10 py-4 bg-white text-accent-orange text-lg font-semibold rounded-lg shadow-md border border-accent-orange hover:bg-orange-50 transition duration-300">
                    <i class="fa-solid fa-calendar-days mr-2"></i> Dohodnout si osobní demo
                </a>
            </div>
        </div>
    </section>

    <!-- Patička -->
    <footer class="py-12" style="background-color: var(--bg-sidebar);">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <p style="color: var(--text-sidebar-inactive);">&copy; 2025 AI Sensei (www.via.academy). Všechna práva vyhrazena.</p>
        </div>
    </footer>


    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            // Funkce pro Intersection Observer
            const revealOnScroll = (entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    } else {
                        // Resetujeme animaci, když prvek opustí obrazovku
                        entry.target.classList.remove('visible');
                    }
                });
            };

            // Vytvoření observeru
            const observer = new IntersectionObserver(revealOnScroll, {
                root: null, // viewport
                threshold: 0.1, // 10% prvku musí být vidět
            });

            // Sledování všech prvků s třídou .reveal
            document.querySelectorAll('.reveal').forEach(el => {
                observer.observe(el);
            });
        });
    </script>

</body>
</html>
