    <!-- 
      KONEC FALEŠNÝCH APLIKACÍ
      Začátek interaktivních prvků (Hotspoty a Modály)
    -->

    <!-- --- Hotspoty (Interaktivní body) --- -->
    
    <!-- Pohled Profesora -->
    <div class="hotspot" data-modal-target="modal-1" style="top: 360px; left: 100px;">1</div>
    <div class="hotspot" data-modal-target="modal-2" style="top: 140px; left: 1100px;">2</div>
