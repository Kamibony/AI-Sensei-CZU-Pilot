                <span class="text-2xl font-bold" style="color: var(--text-sidebar-active); font-family: 'Poppins', sans-serif;">AI Sensei</span>
                <span class="ml-6 text-lg font-semibold" style="color: var(--text-sidebar-inactive);">Moje lekce</span>
            </div>
            <!-- Profil studenta a Přepínač -->
