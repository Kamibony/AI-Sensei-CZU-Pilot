    <div class="hotspot" data-modal-target="modal-4" style="top: 305px; left: 100px;">4</div>
    <div class="hotspot" data-modal-target="modal-5" style="top: 250px; left: 100px;">5</div>

    <!-- Pohled Studenta (zde jsou, ale budou skryté, dokud se nezobrazí #student-view) -->
    <!-- Hotspoty 6-9 jsou již vloženy do #student-view nahoře -->


    <!-- --- Modální Okna (Vyskakovací bubliny) --- -->
    
    <!-- Všechny modály jsou v jednom overlay kontejneru -->
    <div id="modal-overlay" class="modal-overlay">

        <!-- Modál 0: Vítejte -->
        <div id="modal-0" class="modal-content">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3>Vítejte v AI Sensei!</h3>
            <p>Toto je interaktivní prohlídka, která vám ukáže hlavní funkce AI Sensei. Klikněte na "Další" pro zahájení, nebo prozkoumejte sami klikáním na pulzující oranžová čísla.</p>
            <button class="modal-next-btn" data-modal-next="modal-1">Začít prohlídku</button>
        </div>

        <!-- Modály Profesora (1-5) -->
        <div id="modal-1" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-box-archive mr-2"></i> Krok 1: Knihovna médií</h3>
            <p>Vše začíná zde! V <strong>"Knihovně médií"</strong> nahrajete své existující materiály (PDF, dokumenty). Toto je "mozek" a kontext (RAG), který AI použije k vytvoření obsahu vaší lekce.</p>
            <button class="modal-next-btn" data-modal-next="modal-2">Další krok</button>
        </div>

        <div id="modal-2" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-wand-magic-sparkles mr-2"></i> Krok 2: Editor lekcí</h3>
            <p>Po nahrání souborů kliknete na <strong>"Přidat novou lekci"</strong>. Tím se otevře Editor, kde se děje kouzlo. Propojíte své nahrané soubory s lekcí a pomocí <strong>"AI Generátoru"</strong> vytvoříte:</p>
            <ul class="list-disc list-inside mb-4 text-sm space-y-1">
                <li>Studijní texty a shrnutí</li>
                <li>Prezentace (slajdy)</li>
                <li>Interaktivní kvízy</li>
                <li>Pokročilé testy</li>
                <li>Scénáře pro podcasty</li>
            </ul>
            <button class="modal-next-btn" data-modal-next="modal-3">Další krok</button>
        </div>
        
        <div id="modal-3" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-calendar-check mr-2"></i> Krok 3: Publikování</h3>
            <p>Hotovou lekci jednoduše <strong>přetáhnete</strong> z "Knihovny lekcí" (vpravo) přímo do kalendáře v <strong>"Plánu výuky"</strong>. Tím lekci publikujete a zpřístupníte studentům v daný den.</p>
            <button class="modal-next-btn" data-modal-next="modal-4">Další krok</button>
        </div>

        <div id="modal-4" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-chart-line mr-2"></i> Krok 4: Analýza (Po hodině)</h3>
            <p>V sekci <strong>"Analýza"</strong> uvidíte, jak si vaši studenti vedou. Systém automaticky vyhodnotí testy a ukáže vám přehledné grafy, průměrné skóre a dokonce i <strong>"AI Postřehy"</strong> pro každého studenta zvlášť.</p>
            <button class="modal-next-btn" data-modal-next="modal-5">Další krok</button>
        </div>
        
        <div id="modal-5" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-users mr-2"></i> Krok 5: Správa a Komunikace</h3>
            <p>V sekcích <strong>"Studenti"</strong> a <strong>"Interakce"</strong> spravujete svou třídu. Můžete zde odpovídat na dotazy, které vám studenti položili přes "Konzultace", a udržovat s nimi přímý kontakt.</p>
            <!-- Tlačítko nyní vede na Krok 6 (pohled studenta) -->
            <button class="modal-next-btn" data-modal-next="modal-6">Podívat se jako student</button>
        </div>

        <!-- Modály Studenta (6-9) -->
        <div id="modal-6" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-user-graduate mr-2"></i> Pohled Studenta: Lekce</h3>
            <p>A takto to vidí student! Místo editoru vidí publikované lekce. Po kliknutí na kartu se mu zobrazí veškerý obsah, který jste připravili.</p>
            <button class="modal-next-btn" data-modal-next="modal-7">Další (Obsah)</button>
        </div>
        
        <div id="modal-7" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-layer-group mr-2"></i> Různé typy obsahu</h3>
            <p>Student má přístup ke všem formátům, které jste vygenerovali: textům, prezentacím, kvízům (na procvičení) i hodnoceným <strong>Testům</strong> a <strong>Podcastům</strong> (pro poslech na cestách).</p>
            <button class="modal-next-btn" data-modal-next="modal-8">Další (AI)</button>
        </div>

        <div id="modal-8" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-robot mr-2"></i> AI Asistent Studenta</h3>
            <p>Toto je klíčová funkce. Student může klást otázky <strong>"AI Asistentovi"</strong>, který odpovídá *pouze* na základě kontextu (vašich PDF), který jste pro danou lekci nastavili. Je to bezpečný a soukromý tutor.</p>
            <button class="modal-next-btn" data-modal-next="modal-9">Další (Chat)</button>
        </div>

        <div id="modal-9" class="modal-content" style="display: none;">
            <span class="modal-close-btn" data-modal-close>&times;</span>
            <h3><i class="fa-solid fa-message mr-2"></i> Konzultace</h3>
            <p>Pokud AI asistent nestačí, student může pomocí tlačítka <strong>"Konzultace"</strong> poslat přímou zprávu vám (profesorovi). Tuto zprávu uvidíte ve vaší sekci "Interakce".</p>
            <button class="modal-next-btn" data-modal-next="modal-0">Dokončit prohlídku</button>
        </div>

    </div>


    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const overlay = document.getElementById('modal-overlay');
            const allModals = overlay.querySelectorAll('.modal-content');
            const hotspots = document.querySelectorAll('.hotspot');

            const professorView = document.getElementById('professor-view');
            const studentView = document.getElementById('student-view');
            const switchToStudentBtn = document.getElementById('switch-to-student-btn');
            const switchToProfessorBtn = document.getElementById('switch-to-professor-btn');
            
            // --- Funkce pro zobrazení ---

            // Funkce pro přepnutí pohledu
            function switchView(view) {
                if (view === 'student') {
                    professorView.style.display = 'none';
                    studentView.style.display = 'flex'; // Student view je flex-col
                } else {
                    professorView.style.display = 'flex'; // Professor view je flex
                    studentView.style.display = 'none';
                }
            }

            // Funkce pro zobrazení modálu
            function showModal(modalId) {
                allModals.forEach(modal => {
                    modal.style.display = 'none'; // Skryjeme všechny
                });
                
                const modalToShow = document.getElementById(modalId);
                if (modalToShow) {
                    modalToShow.style.display = 'block';
                    overlay.classList.add('visible');
                }
            }

            // Funkce pro skrytí všech modálů
            function hideAllModals() {
                overlay.classList.remove('visible');
                // Dáme malou prodlevu před skrytím, aby stihla proběhnout animace
                setTimeout(() => {
                    allModals.forEach(modal => {
                        modal.style.display = 'none';
                    });
                }, 300);
            }

            // --- PŘIŘAZENÍ EVENTŮ ---

            // Zobrazit první modál (Vítejte) při načtení
            setTimeout(() => {
                showModal('modal-0');
            }, 500); // Malá prodleva po načtení

            // Kliknutí na hotspoty
            hotspots.forEach(hotspot => {
                hotspot.addEventListener('click', () => {
                    const modalId = hotspot.getAttribute('data-modal-target');
                    showModal(modalId);
                });
            });

            // Ruční přepínání pohledů
            switchToStudentBtn.addEventListener('click', () => {
                switchView('student');
                // Zobrazíme první modál studenta
                showModal('modal-6');
            });

            switchToProfessorBtn.addEventListener('click', () => {
                switchView('professor');
                // Zobrazíme první modál profesora
                showModal('modal-1');
            });


            // Kliknutí na tlačítko "Další" (ŘÍZENÍ PROHLÍDKY)
            document.querySelectorAll('.modal-next-btn').forEach(button => {
                button.addEventListener('click', () => {
                    const nextModalId = button.getAttribute('data-modal-next');
                    const currentModalId = button.closest('.modal-content').id;

                    // SPECIÁLNÍ PŘÍPAD: Přepnutí z prof na studenta (Krok 5 -> 6)
                    if (currentModalId === 'modal-5' && nextModalId === 'modal-6') {
                        hideAllModals();
                        setTimeout(() => {
                            switchView('student');
                            showModal('modal-6');
                        }, 300);
                        return; // Zastavíme normální tok
                    }
                    
                    // SPECIÁLNÍ PŘÍPAD: Přepnutí zpět na profa (Krok 9 -> 0)
                    if (currentModalId === 'modal-9' && nextModalId === 'modal-0') {
                         hideAllModals();
                         setTimeout(() => {
                            switchView('professor');
                            showModal('modal-0');
                         }, 300);
                         return;
                    }

                    // Normální tok (zůstáváme ve stejném pohledu)
                    if (nextModalId === 'modal-0') {
                        hideAllModals();
                        setTimeout(() => showModal('modal-0'), 300);
                    } else {
                        showModal(nextModalId);
                    }
                });
            });

            // Kliknutí na tlačítko "Zavřít" (křížek)
            document.querySelectorAll('[data-modal-close]').forEach(button => {
                button.addEventListener('click', () => {
                    hideAllModals();
                });
            });

            // Kliknutí na overlay (mimo obsah modálu)
            overlay.addEventListener('click', (e) => {
                // Zavřeme pouze pokud se kliklo na overlay, ne na jeho potomky (modal-content)
                if (e.target === overlay) {
                    hideAllModals();
                }
            });
        });
    </script>

</body>
</html>
