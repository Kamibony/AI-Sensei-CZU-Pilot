<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interaktivní Průvodce AI Sensei</title>
    <!-- Načtení Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Načtení ikon Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* Definice barev podle via.academy */
        :root {
            --bg-sidebar: #276749; /* Tmavě zelená */
            --bg-sidebar-active: #2F855A; /* Světlejší zelená (aktivní) */
            --text-sidebar-inactive: #C6F6D5; /* Bledě zelený text */
            --text-sidebar-active: #FFFFFF; /* Bílý text */
            --bg-content: #F4F7F6; /* Velmi světle šedozelené pozadí */
            --bg-card: #FFFFFF; /* Bílé karty */
            --text-hlavni: #2D3748; /* Tmavý text */
            --accent-green: #38A169; /* Akcentní zelená */
            --accent-orange: #DD6B20; /* Akcentní oranžová */
        }

        /* Vlastní písma (pokud jsou potřeba) */
        body {
            font-family: 'Inter', sans-serif; /* Předpokládáme použití 'Inter' nebo podobného moderního písma */
            background-color: var(--bg-content);
            overflow: hidden; /* Zabráníme posouvání stránky pod aplikací */
        }

        /* --- Styly pro interaktivní Hotspoty --- */
        .hotspot {
            position: absolute;
            width: 40px;
            height: 40px;
            background-color: rgba(221, 107, 32, 0.9); /* Oranžový akcent */
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 0 15px rgba(221, 107, 32, 0.7);
            z-index: 100;
            transition: all 0.3s ease;
            
            /* Pulzující animace */
            animation: pulse 2s infinite;
        }

        .hotspot:hover {
            transform: scale(1.1);
        }

        @keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(221, 107, 32, 0.7);
            }
            70% {
                box-shadow: 0 0 0 20px rgba(221, 107, 32, 0);
            }
            100% {
                box-shadow: 0 0 0 0 rgba(221, 107, 32, 0);
            }
        }

        /* --- Styly pro Modální Okna (Bubliny) --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.6);
            display: none; /* Skryté ve výchozím stavu */
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-content {
            background-color: var(--bg-card);
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            width: 90%;
            max-width: 500px;
            padding: 2.5rem; /* 40px */
            position: relative;
            transform: scale(0.9);
            opacity: 0;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        
        /* Styl pro zobrazení modálu */
        .modal-overlay.visible {
            display: flex;
        }
        .modal-overlay.visible .modal-content {
            transform: scale(1);
            opacity: 1;
        }

        .modal-close-btn {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 24px;
            color: #999;
            cursor: pointer;
            transition: color 0.2s;
        }
        .modal-close-btn:hover {
            color: var(--text-hlavni);
        }

        .modal-content h3 {
            color: var(--accent-green);
            font-size: 1.75rem; /* 28px */
            font-weight: 700;
            margin-bottom: 1rem; /* 16px */
            font-family: 'Poppins', sans-serif;
        }
        
        .modal-content p {
            color: var(--text-hlavni);
            font-size: 1rem; /* 16px */
            line-height: 1.6;
            margin-bottom: 1.5rem; /* 24px */
        }

        .modal-next-btn {
            background-color: var(--accent-green);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .modal-next-btn:hover {
            background-color: var(--bg-sidebar-active);
        }

    </style>
</head>
